# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.
#
# Only needed if you run the scripts/ data-import tools locally.
# The browser app does NOT read this file — the Supabase anon URL + key are
# hardcoded in js/core/config.js (safe: public by design, protected by RLS).

# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Service role key — FULL database access. Never expose to the browser or commit.
# Used only by scripts/seed-from-localstorage.py for the one-time data import.
# Rotate after initial setup.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (needed by the classifier skill if/when you re-enable it)
# Get from Supabase dashboard → Project Settings → Database → Connection string
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=
